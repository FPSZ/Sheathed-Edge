{
  "$schema": "D:\\AI\\Local\\MCP\\registry.schema.json",
  "tools": [
    {
      "name": "filesystem/search",
      "description": "Search local files within approved project roots.",
      "type": "stdio_mcp",
      "transport": "stdio",
      "command": [
        "python",
        "-m",
        "mcp_servers.filesystem_search"
      ],
      "env": {},
      "workdir": "D:\\AI\\Local",
      "timeout_ms": 30000,
      "retry": {
        "max_attempts": 1,
        "backoff_ms": 0
      },
      "allowed_paths": [
        "D:\\AI\\Local\\Core",
        "D:\\AI\\Local\\Plugins",
        "D:\\AI\\Local\\Datasets",
        "D:\\AI\\Local\\Eval",
        "D:\\AI\\Local\\Logs",
        "D:\\AI\\Local\\Templates",
        "D:\\AI\\Local\\Writeups"
      ],
      "allowed_hosts": [],
      "allowed_cidrs": [],
      "allowed_schemes": [],
      "allowed_ports": [],
      "plugin_scope": [
        "awdp"
      ],
      "parameter_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1
          },
          "roots": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 10
          }
        }
      },
      "capabilities": [
        "tools"
      ],
      "enabled": true
    },
