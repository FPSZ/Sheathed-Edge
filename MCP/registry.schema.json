{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToolRouterRegistry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tools"
  ],
  "properties": {
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool"
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/capability"
      },
      "default": []
    },
    "prompts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/capability"
      },
      "default": []
    }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "name",
        "enabled"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "enabled": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "type",
        "transport",
        "command",
        "workdir",
        "timeout_ms",
        "retry",
        "allowed_paths",
        "allowed_hosts",
        "plugin_scope",
        "parameter_schema",
        "capabilities",
        "enabled"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "stdio_mcp",
            "http_mcp"
          ]
        },
        "transport": {
          "type": "string",
          "enum": [
            "stdio",
            "http"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "workdir": {
          "type": "string",
          "minLength": 1
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1
        },
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_attempts",
            "backoff_ms"
          ],
          "properties": {
            "max_attempts": {
              "type": "integer",
              "minimum": 1
            },
            "backoff_ms": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_hosts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_cidrs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "allowed_schemes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "allowed_ports": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "default": []
        },
        "plugin_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "parameter_schema": {
          "type": "object"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "tools",
              "resources",
              "prompts"
            ]
          }
        },
        "enabled": {
          "type": "boolean"
        }
      }
    }
  }
}
